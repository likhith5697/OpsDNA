# Grafana Cloud Prometheus (query-only -- metrics are scraped/pushed by an
# agent running in the AKS cluster itself, nothing in this repo pushes them)
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-66-prod-us-east-3.grafana.net/api/prom
GRAFANA_CLOUD_USERNAME=
GRAFANA_CLOUD_API_KEY=

# SRE Agent thresholds
SRE_ERROR_RATE_THRESHOLD=5.0
SRE_P99_LATENCY_THRESHOLD=2000.0
SRE_ORDER_SUCCESS_THRESHOLD=95.0

# Grafana Cloud Loki (query-only; optional -- query_logs tool degrades
# gracefully without it). Reuses GRAFANA_CLOUD_API_KEY above as the password.
GRAFANA_LOKI_URL=https://logs-prod-042.grafana.net
GRAFANA_LOKI_USERNAME=
